# Legacy Climate Analytics Data API (provide-api.iiasa.ac.at).
# Used for: /impact-time, /unavoidable-risk, /impact-geo, /geo-shape,
# /avoiding-impacts, /avoiding-reference.
VITE_DATA_API_URL=https://provide-api.iiasa.ac.at/api

# New Hono adapter (this repo's api/ directory).
# Used for the indicator catalogue surface: /meta, /indicators,
# /scenarios, /sectors, /units, /geography-types, /geographies, etc.
VITE_API_URL=http://localhost:8080/api

# Strapi CMS for editorial content.
VITE_HEROKU_URL=https://provide-strapi.herokuapp.com
VITE_STRAPI_LOCALE=en
