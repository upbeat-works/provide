# ─── APIs ────────────────────────────────────────────────────────────────────

# Catalog API — the Hono adapter in this repo's api/ directory (D1 + ixmp4).
# Serves the convention-driven catalogue surface:
#   /geographies (+ /geographies/types), /catalog, /study-locations,
#   /likelihoods, /indicators, /scenarios, /tags, /impact-time, /unavoidable-risk.
# Point this at the API runtime you run locally:
#   - Workers runtime  (`npm run dev:api`)      → http://localhost:8787/api
#   - Bun runtime      (`npm run dev:api:node`) → http://localhost:8080/api
VITE_API_URL=http://localhost:8787/api

# Legacy Climate Analytics Data API (provide-api.iiasa.ac.at).
# Still used for: /impact-time, /unavoidable-risk, /impact-geo, /geo-shape,
# /avoiding-impacts, /avoiding-reference.
VITE_DATA_API_URL=https://provide-api.iiasa.ac.at/api

# Strapi CMS for editorial content (indicator/scenario descriptions, stories).
VITE_HEROKU_URL=https://provide-strapi.herokuapp.com
VITE_STRAPI_LOCALE=en

# ─── App ─────────────────────────────────────────────────────────────────────

# Public base URL of the app, used to build embed/share links.
VITE_APP_URL=http://localhost:5173

# Screenshot service used to render chart images for downloads/embeds.
VITE_SCREENSHOT_URL=

# Set to "true" for the public-facing build (toggles internal-only UI).
VITE_IS_PUBLIC_VERSION=false

# ─── Mapbox (maps + geo-shape views) ─────────────────────────────────────────

VITE_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-access-token
VITE_MAPBOX_STYLE_LIGHT=mapbox://styles/mapbox/light-v11
VITE_MAPBOX_STYLE_SATELLITE=mapbox://styles/mapbox/satellite-v9
VITE_MAPBOX_STYLE_STUDY_LOCATIONS=mapbox://styles/mapbox/light-v11
